ARG BASE_IMAGE=rocm/pytorch:rocm6.2_ubuntu22.04_py3.10_pytorch_2.5.0
FROM ${BASE_IMAGE}

RUN pip install --no-cache-dir diffusers==0.37.1 accelerate bitsandbytes fastapi uvicorn pydantic

WORKDIR /app
COPY server.py /app/server.py

ENV HSA_OVERRIDE_GFX_VERSION=11.0.0

EXPOSE 8188
ENTRYPOINT ["python3", "server.py"]
